# Example GitHub Actions workflow that auto-merges any open PR from
# the `announcements` branch into `main` on a weekly schedule.
#
# Save as .github/workflows/announcements-merge.yaml in your course repo.
# Adjust the cron, branch names, and merge strategy to taste.

name: Auto-merge announcements PR

on:
  schedule:
    # 5 PM EST = 22:00 UTC. After DST starts, change to '0 21 * * 0' for 5 PM EDT.
    - cron: '0 22 * * 0'
  workflow_dispatch:

jobs:
  merge:
    runs-on: ubuntu-latest
    permissions:
      pull-requests: write
      contents: write
    steps:
      - name: Find open PR from announcements branch
        id: find-pr
        run: |
          PR_NUMBER=$(gh pr list --head announcements --base main --state open --json number --jq '.[0].number')
          echo "pr_number=$PR_NUMBER" >> "$GITHUB_OUTPUT"
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Merge PR (if any)
        if: steps.find-pr.outputs.pr_number != ''
        run: |
          gh pr merge ${{ steps.find-pr.outputs.pr_number }} \
            --merge \
            --delete-branch=false
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
